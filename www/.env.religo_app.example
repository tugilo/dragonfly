# Religo 本番サーバー（/var/www/laravel/religo_app）
# 初回: cp .env.religo_app.example .env → DB_PASSWORD 等を編集 → php artisan key:generate
# 詳細: docs/DEPLOYMENT.md

APP_NAME=Religo
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://religo.tugilo.com

APP_TIMEZONE=Asia/Tokyo
APP_LOCALE=ja
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ja_JP

LOG_CHANNEL=stack
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=religo_app
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file

MAIL_MAILER=log

RELIGO_MEMBER_MERGE_TOKEN=
RELIGO_ACTING_USER_FALLBACK=false

VITE_APP_NAME="${APP_NAME}"
