# Religo 本番サーバー（/var/www/laravel/religo_app）
# 初回: cp .env.religo_app.example .env → DB_PASSWORD 等を編集 → php artisan key:generate
# 詳細: docs/DEPLOYMENT.md

APP_NAME=Religo
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://religo.tugilo.com

APP_TIMEZONE=Asia/Tokyo
APP_LOCALE=ja
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ja_JP

LOG_CHANNEL=stack
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=religo_app
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file

MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@religo.tugilo.com"
MAIL_FROM_NAME="${APP_NAME}"

# 初回登録の確認コードを API に返す（本番は false 必須）
RELIGO_REGISTRATION_EXPOSE_DEBUG_CODE=false
RELIGO_ACTING_USER_FALLBACK=false

VITE_APP_NAME="${APP_NAME}"
