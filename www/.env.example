APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_TIMEZONE=Asia/Tokyo
APP_LOCALE=ja
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ja_JP

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Member マージ API（/api/admin/member-merge）。空のときエンドポイントは 404。
RELIGO_MEMBER_MERGE_TOKEN=

# 開発レガシー: 認証無しでも「users.id 昇順で先頭」を現在ユーザーとして扱う。config デフォルトは false（SPEC-020 Phase A）。ローカルで従来挙動が必要なら true。
RELIGO_ACTING_USER_FALLBACK=true

# Zoom 連携（SPEC-012 / 1 to 1 取り込み）。
# ZOOM_REDIRECT_URI は必須（全ユーザー共通 callback）。Client ID/Secret は設定画面でユーザーごとに登録可能（Phase 189）。
# 以下は移行期間のサーバー共通フォールバック（空でも可）。
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_REDIRECT_URI=
ZOOM_WEBHOOK_SECRET_TOKEN=
# 任意（既定値あり）
# ZOOM_API_BASE_URL=https://api.zoom.us/v2
# ZOOM_OAUTH_BASE_URL=https://zoom.us

VITE_APP_NAME="${APP_NAME}"
